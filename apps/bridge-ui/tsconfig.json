{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "composite": false,
    "noEmit": true,
    "allowImportingTsExtensions": true
  },
  "include": ["src/**/*", "src/**/*.vue"]
}
