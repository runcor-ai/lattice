{
  "name": "@runcor/bridge-api",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "./dist/server.js",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "start": "node ./dist/server.js",
    "dev": "node --import tsx ./src/server.ts",
    "clean": "rm -rf dist *.tsbuildinfo",
    "lint": "eslint src"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "fastify": "^5.2.1",
    "@fastify/static": "^8.0.4",
    "zod": "^3.24.1",
    "better-sqlite3": "^11.7.0",
    "@runcor/bridge-shared": "workspace:*",
    "@runcor/runtime": "workspace:*",
    "@runcor/trace": "workspace:*",
    "@runcor/engine": "workspace:*",
    "@runcor/capabilities": "workspace:*",
    "@runcor/jobs": "workspace:*",
    "@runcor/memory": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "@types/better-sqlite3": "^7.6.12"
  }
}
