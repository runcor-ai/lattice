{
  "name": "@runcor/runtime",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "lint": "eslint src"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@runcor/trace": "workspace:*",
    "@runcor/capabilities": "workspace:*",
    "@runcor/engine": "workspace:*",
    "@runcor/memory": "workspace:*",
    "@runcor/substrate": "workspace:*",
    "@runcor/decider": "workspace:*",
    "@runcor/dialectic": "workspace:*",
    "@runcor/jobs": "workspace:*",
    "@runcor/rpp-parser": "workspace:*",
    "better-sqlite3": "^11.7.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12"
  }
}
